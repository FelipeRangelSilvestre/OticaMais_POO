# Copie este arquivo para ".env" e ajuste os valores.
# NUNCA suba o arquivo ".env" real para o Git (já está no .gitignore).

# --- PostgreSQL local ---
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=otica_mais

# --- Servidor ---
PORT=3000

# --- Autenticação (gere uma string aleatória qualquer, ex: openssl rand -hex 32) ---
JWT_SECRET=troque_esta_chave_por_uma_string_aleatoria_longa

# --- Assistente IA (chave fica só aqui no backend, nunca no front) ---
ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui
